{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://wildconstruct.dev/schemas/signal-rack-recipe.schema.json",
  "title": "Signal Rack Recipe",
  "description": "A portable description of a Signal Rack instance: source, process, three outputs, profiles, ranges/units, seed, timebase, visualization, bake, and optional Wild Construct payload metadata. A recipe is the saved behaviour; the AE rig is one rendering of it.",
  "type": "object",
  "required": ["type", "id", "version", "rackType", "source", "outputs"],
  "properties": {
    "type": { "const": "wildconstruct.signalRecipe" },
    "name": { "type": "string" },
    "id": { "type": "string", "description": "Stable recipe id, e.g. 'sg_pulse_001'." },
    "version": { "type": "string", "description": "Recipe schema/content version, e.g. '0.2'." },
    "rackType": {
      "type": "string",
      "enum": ["generator", "probe", "processor", "driver"],
      "description": "generator = synthesizes a signal; probe = samples media; processor = shapes an input; driver = product-specific output mapping."
    },
    "inputs": {
      "type": "object",
      "description": "Optional sidechain bindings. null = unconnected. A string is a reference id of another rack output, e.g. 'sg_audio_001:A'.",
      "properties": {
        "A": { "type": ["string", "null"] },
        "B": { "type": ["string", "null"] },
        "C": { "type": ["string", "null"] }
      }
    },
    "source": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["sine", "square", "pulse", "pulseNarrow", "ramp", "saw", "noise", "randomWalk", "linked", "lumaProbe", "triangle", "audioPlaceholder"]
        },
        "rate": { "type": "number", "description": "Hz (cycles per second)." },
        "amount": { "type": "number" },
        "phase": { "type": "number", "description": "Cycle offset in turns (0..1)." },
        "offset": { "type": "number" },
        "sourceLayer": { "type": "string", "description": "For probe sources." },
        "position": { "type": "array", "items": { "type": "number" }, "description": "Probe sample point [x,y]." },
        "sampleKernel": { "type": "string", "enum": ["1x1", "3x3_average", "5x5_average"] },
        "sampleMode": { "type": "string", "enum": ["preEffect", "postEffect"] }
      }
    },
    "process": {
      "type": "object",
      "description": "Optional shaping applied before output mapping. These fields mirror the current WGSL/CPU-reference process stage and Signal Lab export shape.",
      "properties": {
        "smooth": { "type": "number", "description": "0..1 box-average lag amount." },
        "gain": { "type": "number", "description": "Contrast gain around 0.5 before output mapping." },
        "bias": { "type": "number", "description": "Offset applied after gain." },
        "quantize": { "type": "number", "description": "0 disables quantization; values > 1 select the number of quantization steps." },
        "quantizeSteps": { "type": "integer", "description": "Legacy alias for quantize." },
        "gate": { "type": "number", "description": "0 disables pointwise gate; otherwise threshold in normalized units." },
        "lag": { "type": "number", "description": "0..1 finite-window lag approximation." },
        "warp": { "type": "number", "description": "-1..1 contrast S-curve." },
        "fold": { "type": "number", "description": "0..1 triangle-wave fold amount." },
        "sat": { "type": "number", "description": "0..1 soft saturation amount." },
        "threshold": { "type": "number" },
        "hysteresis": { "type": "number" },
        "invert": { "type": "boolean" },
        "rectify": { "type": "boolean" },
        "winLeft": { "type": "number", "description": "Left edge of the feathered region window, 0..1 across the evaluated span." },
        "winRight": { "type": "number", "description": "Right edge of the feathered region window, 0..1 across the evaluated span." },
        "winFeatherL": { "type": "number", "description": "Left feather size as a normalized span fraction." },
        "winFeatherR": { "type": "number", "description": "Right feather size as a normalized span fraction." },
        "modTarget": { "type": ["string", "integer"], "description": "Sidechain modulation target: off/amp/rate/phase or the matching engine code." },
        "modDepth": { "type": "number", "description": "Sidechain modulation depth." },
        "zDepth": { "type": "number", "description": "Third-signal phase-bend depth." }
      }
    },
    "outputs": {
      "type": "object",
      "required": ["A"],
      "properties": {
        "A": { "$ref": "#/definitions/outputDef" },
        "B": { "$ref": "#/definitions/outputDef" },
        "C": { "$ref": "#/definitions/outputDef" }
      }
    },
    "timebase": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["compTime", "layerTime"] },
        "seed": { "type": "integer", "description": "Deterministic seed. Random behaviour MUST be reproducible unless explicitly randomized." }
      }
    },
    "_channelY": {
      "$ref": "#/definitions/channelDef",
      "description": "Signal Lab authoring metadata for the second browser channel. Native v1 still publishes Output A/B/C from a single recipe."
    },
    "_drive": {
      "type": "string",
      "enum": ["x", "y", "mult", "mix", "diff", "min", "max"],
      "description": "Signal Lab authoring metadata for how Channel X/Y combine into the displayed driver."
    },
    "_tool": {
      "type": "object",
      "description": "Signal Lab private round-trip state for UI, link, sidechain, lfo, CRT, applied target, and other authoring controls. Hosts may preserve it but should not treat it as the native plugin contract.",
      "additionalProperties": true,
      "properties": {
        "x": { "$ref": "#/definitions/channelDef" },
        "y": { "$ref": "#/definitions/channelDef" },
        "proc": { "type": "object" },
        "win": { "type": "object" },
        "drive": { "type": "string", "enum": ["x", "y", "mult", "mix", "diff", "min", "max"] },
        "side": {
          "type": "object",
          "properties": {
            "target": { "type": "string", "enum": ["off", "amp", "rate", "phase"] },
            "depth": { "type": "number" }
          }
        },
        "z": { "type": "object" },
        "lfo": { "type": "object" },
        "view": { "type": "string" },
        "crt": { "type": "boolean" },
        "speed": { "type": "number" },
        "applied": { "type": "object" }
      }
    },
    "visualization": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["none", "guide_waveform", "bar_meter", "gate_blocks", "value_readout", "waveform", "bars", "vectorscope", "polar", "heat", "applied"] },
        "showProbe": { "type": "boolean" },
        "showOutputLabels": { "type": "boolean" }
      }
    },
    "bake": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["none", "outputKeyframes", "targetKeyframes"] },
        "simplify": { "type": "boolean" },
        "preservePeaks": { "type": "boolean" }
      }
    },
    "wildConstruct": {
      "type": "object",
      "description": "Optional richer payload metadata for WC tools. Generic AE users never see this.",
      "properties": {
        "rackId": { "type": "string" },
        "channels": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "e.g. { 'A.norm':'normalized', 'A.gate':'gate', 'A.trigger':'trigger' }."
        },
        "targetIdentity": { "type": "string", "description": "e.g. 'entropy_birth_driver'." }
      }
    },
    "compatibilityTags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "e.g. ['ae:expression-only', 'wc:entropy', 'wc:cathode']."
    }
  },
  "definitions": {
    "channelDef": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["sine", "square", "pulse", "pulseNarrow", "ramp", "saw", "noise", "randomWalk", "linked", "lumaProbe", "triangle", "audioPlaceholder"] },
        "src": { "type": ["string", "number"], "description": "Signal Lab internal source id or source name." },
        "rate": { "type": "number" },
        "amount": { "type": "number" },
        "phase": { "type": "number" },
        "offset": { "type": "number" },
        "smooth": { "type": "number" },
        "seed": { "type": "integer" }
      }
    },
    "outputDef": {
      "type": "object",
      "required": ["name", "profile"],
      "properties": {
        "name": { "type": "string", "description": "AE effect/channel name, e.g. 'Luma Normalized'." },
        "profile": { "type": "string", "description": "Output profile id, e.g. 'normalized_0_1', 'gate', 'entropy_birth_driver'." },
        "range": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
        "units": { "type": "string" }
      }
    }
  }
}
